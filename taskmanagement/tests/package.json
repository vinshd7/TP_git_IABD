{
  "name": "task-manager-tests",
  "version": "1.0.0",
  "description": "Tests unitaires, intégration et E2E",
  "type": "commonjs",
  "scripts": {
    "test": "jest --detectOpenHandles",
    "test:unit": "jest unit/ --detectOpenHandles",
    "test:integration": "jest integration/ --detectOpenHandles",
    "test:e2e": "jest e2e/ --detectOpenHandles --testTimeout=30000",
    "test:coverage": "jest --coverage --detectOpenHandles"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "selenium-webdriver": "^4.18.1",
    "chromedriver": "^123.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/unit/**/*.test.js",
      "**/integration/**/*.test.js",
      "**/e2e/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "../backend/**/*.js",
      "!../backend/node_modules/**"
    ]
  }
}
